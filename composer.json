{
    "name": "jorisnoo/craft-locale-redirect",
    "description": "Browser locale detection and redirect for Craft CMS",
    "license": "MIT",
    "keywords": ["craft", "cms", "craftcms", "locale", "redirect", "language", "i18n"],
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Noo\\CraftLocaleRedirect\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Noo\\CraftLocaleRedirect\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
